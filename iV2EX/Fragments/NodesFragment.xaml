<UserControl
    x:Class="iV2EX.Fragments.NodesFragment"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:data="using:iV2EX.Model"
    xmlns:local="using:iV2EX.Fragments"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="AllNodesFragment"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <ListView Name="InView" IsItemClickEnabled="True">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="data:NodeModel">
                    <StackPanel Margin="12,8">
                        <TextBlock
                            FontSize="16"
                            Foreground="#FF3D3D3D"
                            MaxLines="1"
                            Text="{x:Bind Title}" />
                        <TextBlock
                            FontSize="14"
                            Foreground="Gray"
                            MaxLines="1"
                            Text="{x:Bind Header}" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>