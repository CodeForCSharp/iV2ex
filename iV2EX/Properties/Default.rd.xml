<!--
    This file contains Runtime Directives used by Native AOT.
-->
<Directives xmlns="http://schemas.microsoft.com/netfx/2013/01/metadata">
  <Application>
    <Assembly Name="*Application*" Dynamic="Required All" />

    <!-- AngleSharp uses reflection for HTML parsing -->
    <Assembly Name="AngleSharp" Dynamic="Required All" />

    <!-- Newtonsoft.Json uses reflection for serialization -->
    <Assembly Name="Newtonsoft.Json" Dynamic="Required All" />

    <!-- System.Reactive / Rx.NET -->
    <Assembly Name="System.Reactive" Dynamic="Required All" />

    <!-- WinUI / CsWinRT generated types -->
    <Assembly Name="Microsoft.WinUI" Dynamic="Required All" />
    <Assembly Name="Microsoft.UI.Xaml" Dynamic="Required All" />
    <Assembly Name="WinRT.Runtime" Dynamic="Required All" />

    <!-- Windows SDK projections -->
    <Namespace Name="Microsoft.UI.Xaml.Controls" Serialize="Required All" />
    <Namespace Name="Microsoft.UI.Xaml" Serialize="Required All" />
  </Application>
</Directives>
